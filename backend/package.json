{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "serve": "nodemon dist/server.js",
    "watch": "tsc --watch",
    "migrate:create": "npx migrate-mongo create --file ./dist/configs/migrate-mongo.config.js",
    "migrate:up": "npx migrate-mongo up --file ./dist/configs/migrate-mongo.config.js",
    "migrate:down": "npx migrate-mongo down --file ./dist/configs/migrate-mongo.config.js",
    "migrate:status": "npx migrate-mongo status --file ./dist/configs/migrate-mongo.config.js"
  },
  "author": "soham",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/migrate-mongo": "^10.0.5",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "migrate-mongo": "^12.1.3",
    "mongo-migrate": "^2.0.2",
    "mongoose": "^8.14.1",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2"
  }
}
