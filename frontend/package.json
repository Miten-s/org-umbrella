{
  "name": "umbrella",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "eslint": "eslint --cache \"src/**/*.{js,ts,tsx.}\" --config ./eslint.config.js",
    "eslint:ci": "eslint \"src/**/*.{js,ts,tsx}\" --cache --quiet --config ./eslint.config.js",
    "eslint:fix": "eslint --fix \"src/**/*.{js,ts,tsx}\" --config ./eslint.config.js",
    "prettier-format": "prettier --config .prettierrc.js 'src/**/*.ts' --write",
    "prettier": "prettier src --check",
    "prettier:ci": "prettier src --check --loglevel error",
    "prettier:fix": "prettier src --write",
    "i18next": "npx i18next --config i18next-parser.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@tailwindcss/vite": "^4.1.5",
    "@types/react-router-dom": "^5.3.3",
    "ag-grid-community": "^35.2.0",
    "ag-grid-react": "^35.2.0",
    "axios": "^1.9.0",
    "dayjs": "^1.11.13",
    "fs-extra": "^11.3.0",
    "i18next": "^25.1.2",
    "i18next-browser-languagedetector": "^8.1.0",
    "i18next-http-backend": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-flatpickr": "^4.0.10",
    "react-hook-form": "^7.56.3",
    "react-hot-toast": "^2.5.2",
    "react-i18next": "^15.5.1",
    "react-loader-spinner": "^8.0.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.5.3",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "signature_pad": "^5.0.7",
    "tailwind-merge": "^3.2.0",
    "translation-check": "^1.1.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/i18next": "^13.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.3.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^8.0.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.5"
  }
}
